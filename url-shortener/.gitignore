# ─────────────────────────────────────────────────────────
# .gitignore — URL Shortener Project
# Java + Spring Boot + React + Docker
# ─────────────────────────────────────────────────────────

# ── Java / Maven ──────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
!**/src/main/**
!**/src/test/**
.mvn/
mvnw.cmd
hs_err_pid*

# ── Spring Boot ───────────────────────────────────────────
*.log
spring.log
application-local.yml

# ── Environment & Secrets (NEVER commit these) ────────────
.env
.env.local
.env.production
*.secret
secrets/

# ── IDE ───────────────────────────────────────────────────
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── React / Node ──────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local
frontend/coverage/
npm-debug.log*
yarn-error.log

# ── Docker ────────────────────────────────────────────────
# (keep docker-compose.yml but ignore local volume data)
docker-volumes/

# ── OS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
